# Copiar para .env.local e preencher.
# .env.local é ignorado pelo git (ver .gitignore na raiz).

# URL do Web App publicado pelo Apps Script.
# Exemplo: https://script.google.com/macros/s/AKfycb.../exec
VITE_API_URL=

# OAuth 2.0 Client ID criado no Google Cloud Console (Web application).
# Exemplo: 123456789012-abcdef.apps.googleusercontent.com
# Este valor é PÚBLICO por design — pode entrar no bundle.
# Authorized JavaScript origins do client devem incluir:
#   - https://bam-araujo.github.io (produção)
#   - http://localhost:5173       (dev)
VITE_GOOGLE_CLIENT_ID=
